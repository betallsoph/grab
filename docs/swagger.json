                },
                "created_at": {
                    "type": "string"
                },
                "created_by": {
                    "description": "userID của tài xế đóng góp",
                    "type": "integer"
                },
                "description": {
                    "type": "string"
                },
                "distance_m": {
                    "type": "number"
                },
                "id": {
                    "type": "integer"
                },
                "latitude": {
                    "type": "number"
                },
                "longitude": {
                    "type": "number"
                },
