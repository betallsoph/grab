                    "type": "string"
                },
                "category": {
                    "$ref": "#/definitions/internal_modules_survivalmap.Category"
                },
                "description": {
                    "type": "string"
                },
                "latitude": {
                    "type": "number"
                },
                "longitude": {
                    "type": "number"
                },
                "name": {
                    "type": "string"
                }
            }
        },
        "internal_modules_survivalmap.POI": {
