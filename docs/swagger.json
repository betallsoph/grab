                    "type": "string"
                },
                "category": {
                    "$ref": "#/definitions/internal_modules_survivalmap.Category"
                },
                "created_at": {
                    "type": "string"
                },
                "created_by": {
                    "description": "userID của tài xế đóng góp",
                    "type": "integer"
                },
                "description": {
                    "type": "string"
                },
                "id": {
                    "type": "integer"
                },
                "latitude": {
                    "type": "number"
                },
                "longitude": {
                    "type": "number"
                },
                "name": {
                    "type": "string"
                },
                "updated_at": {
                    "type": "string"
                },
                "upvote_count": {
                    "type": "integer"
                }
            }
        },
